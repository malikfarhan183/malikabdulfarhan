PORT=4200
JWT_SECRET=change-this-secret-before-production
JWT_EXPIRES_IN_SECONDS=3600

# Set DATABASE_PROVIDER=mssql to use SQL Server instead of the in-memory demo provider.
# Set DATABASE_PROVIDER=postgres to use Neon/Postgres through DATABASE_URL.
DATABASE_PROVIDER=memory

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clientopsstudio
POSTGRES_AUTO_MIGRATE=false
POSTGRES_SSL=false

MSSQL_AUTO_MIGRATE=false
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=ClientOpsStudio
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrong!Passw0rd
MSSQL_ENCRYPT=false
