{
  "name": "malik-skills-showcase",
  "version": "1.0.0",
  "private": true,
  "description": "Client-facing full-stack skills showcase with React, MUI, JWT auth, Express APIs, and MSSQL-ready persistence.",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "build:api": "node scripts/run-tsc.js -p apps/api/tsconfig.json",
    "build:web": "node scripts/run-vite.js build --config apps/web/vite.config.js",
    "start": "node dist/api/index.js",
    "test": "npm run build:api && node --test apps/api/tests/authService.test.js apps/api/tests/projectService.test.js"
  },
  "dependencies": {
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@mui/icons-material": "^5.8.4",
    "@mui/material": "^5.9.2",
    "express": "^4.17.1",
    "mssql": "^11.0.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-query": "^3.39.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.8.6",
    "@types/react": "^17.0.65",
    "@types/react-dom": "^17.0.20",
    "typescript": "^5.7.2",
    "vite": "^6.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
